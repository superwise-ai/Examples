{
  "_comment": "SW-Sentinel Configuration — copy this file to sentinel_config.json and fill in your credentials",

  "superwise_client_id":     "YOUR_SUPERWISE_CLIENT_ID",
  "superwise_client_secret": "YOUR_SUPERWISE_CLIENT_SECRET",

  "proxy_host": "127.0.0.1",
  "proxy_port": 8080,

  "anthropic_api_base": "https://api.anthropic.com",
  "anthropic_api_key":  "",

  "openai_api_base": "https://api.openai.com",
  "openai_api_key":  "",

  "groq_api_base": "https://api.groq.com",
  "groq_api_key":  "",

  "gemini_api_base": "https://generativelanguage.googleapis.com",
  "gemini_api_key":  "",

  "_comment_token": "proxy_token: optional shared secret. If set, clients must send X-Sentinel-Token header. Recommended when proxy_host is 0.0.0.0.",
  "proxy_token": "",

  "upstream_timeout_seconds": 120,

  "on_superwise_error": "fail_open",

  "max_check_chars": 2000,

  "log_level":     "INFO",
  "log_file":      "sw_sentinel.log",
  "violation_log": "sw_sentinel_violations.log",

  "blocked_input_message":  "This request has been blocked by compliance policy. The input content violated one or more security guardrails (PII, jailbreak attempt, or toxic content detected). Please reformulate your request.",
  "blocked_output_message": "The model response has been blocked by compliance policy. The generated content contained sensitive information that cannot be returned. Please rephrase your request.",

  "injection_patterns": [
    "ignore\\s+(all\\s+)?(previous|prior|above|earlier)\\s+(instructions?|prompts?|directives?|rules?)",
    "disregard\\s+(all\\s+)?(previous|prior|above|earlier)\\s+(instructions?|prompts?|directives?|rules?)",
    "forget\\s+(all\\s+)?(previous|prior|above|earlier)\\s+(instructions?|prompts?|directives?|rules?)",
    "(reveal|print|show|repeat|output)\\s+(your\\s+)?(system\\s+prompt|original\\s+instructions?|true\\s+instructions?)",
    "\\bdo\\s+anything\\s+now\\b",
    "override\\s+(your\\s+)?(safety|content\\s+policy|guidelines?|restrictions?|constraints?)"
  ],

  "skip_patterns": [
    "Continue your Paperclip work",
    "You are agent",
    "Base directory for this skill"
  ],

  "_comment_guardrails": [
    "OPTIONAL: To seed guardrails from this config file, add a 'guardrails' block below.",
    "SW-Sentinel will create a single 'SW-Sentinel Guardrails' object in your Superwise",
    "tenant on first run using these settings. If that guardrail already exists, this",
    "block is ignored — your Superwise UI settings are always preserved.",
    "",
    "Leave this block out entirely to manage guardrails through the Superwise UI only.",
    "If omitted and your tenant is empty, a default PII Detection guardrail is created.",
    "",
    "To enable: copy the block below, remove this comment key, and add it to your config.",
    "",
    "  \"guardrails\": {",
    "    \"input\": [",
    "      {\"type\": \"pii_detection\", \"threshold\": 0.5, \"categories\": [\"US_SSN\", \"CREDIT_CARD\", \"US_BANK_NUMBER\"]},",
    "      {\"type\": \"detect_jailbreak\", \"threshold\": 0.7}",
    "    ],",
    "    \"output\": [",
    "      {\"type\": \"pii_detection\", \"threshold\": 0.5, \"categories\": [\"US_SSN\", \"CREDIT_CARD\", \"US_BANK_NUMBER\"]}",
    "    ]",
    "  }",
    "",
    "Available types: pii_detection, detect_jailbreak, toxicity, restricted_topics,",
    "allowed_topics, competitor_check, correct_language, string_check"
  ]
}
